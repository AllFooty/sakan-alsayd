# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# Feature flags
# Any value other than the literal string "true" disables the feature.
NEXT_PUBLIC_SHOW_LOCATIONS=false

# Tooling
# Personal Access Token for scripts/check-migrations.mjs (predeploy gate).
# Generate at https://supabase.com/dashboard/account/tokens — NOT a project API key.
SUPABASE_ACCESS_TOKEN=sbp_...
