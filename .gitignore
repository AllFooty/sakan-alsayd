# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# cloudflare
.open-next/
.wrangler/

# supabase cli temp
supabase/.temp/

# MCP config — may contain personal access tokens (e.g. Supabase sbp_*)
.mcp.json

# internal planning documents
CLOUDFLARE_MIGRATION_PLAN.md
Sakan_Alsayd_Platform_Proposal*.md

# local data dumps — PII (resident lists, etc). Never commit.
/data/
/scripts/import-residents/reports/

# typescript
*.tsbuildinfo
next-env.d.ts
